{"cell_type":"code","exec_count":11,"id":"a3c083","input":"# By County, remove rows with NA in 'county' (RQ2)\n\ncounty_summary <- data_clean %>%\n  filter(!is.na(county)) %>%       # Remove NAs in county\n  count(county, cause_of_death_simplified)\n\nprint(county_summary)  # Check the summary\n\n# Load tidyr to use complete()\nlibrary(tidyr)\n\n# Make sure every county has all causes (fill missing with 0)\ncounty_summary_complete <- county_summary %>% \n  tidyr::complete(county, cause_of_death_simplified, fill = list(n = 0))\n\n# Plot dodged bar chart (side-by-side bars)\nggplot(county_summary_complete, aes(x = county, y = n, fill = cause_of_death_simplified)) +\n  geom_col(position = position_dodge(width = 0.8)) +  # side-by-side bars\n  labs(title = \"Mortality Causes by County (2015)\",\n       x = \"County\",\n       y = \"Number of Deaths\",\n       fill = \"Cause of Death\") +\n  theme_minimal() +\n  theme(axis.text.x = element_text(size = 8, angle = 45, hjust = 1))","output":{"0":{"name":"stdout","output_type":"stream","text":"\u001b[90m# A tibble: 7 × 3\u001b[39m\n  county   cause_of_death_simplified     n\n  \u001b[3m\u001b[90m<chr>\u001b[39m\u001b[23m    \u001b[3m\u001b[90m<chr>\u001b[39m\u001b[23m                     \u001b[3m\u001b[90m<int>\u001b[39m\u001b[23m\n\u001b[90m1\u001b[39m Isiolo   Natural                       1\n\u001b[90m2\u001b[39m Laikipia H/E Conflict                  6\n\u001b[90m3\u001b[39m Laikipia Natural                       9\n\u001b[90m4\u001b[39m Laikipia Poached                       9\n\u001b[90m5\u001b[39m Samburu  H/E Conflict                  2\n\u001b[90m6\u001b[39m Samburu  Natural                       8\n\u001b[90m7\u001b[39m Samburu  Poached                       3\n"},"1":{"data":{"image/png":"364c08a16aa082fdbb61473bd0612167134beada","text/plain":"plot without title"},"exec_count":11,"metadata":{"image/png":{"height":420,"width":420}},"output_type":"execute_result"}},"pos":9,"type":"cell"}
{"cell_type":"code","exec_count":12,"id":"30cdc7","input":"# STEP 6: Spatial Map of Elephant Mortality (RQ2)\n\n# Read the shapefile\ncounties <- st_read(\"Laikipia_Samburu_Landscapezip/Laikipia_Samburu_Landscape.shp\")\n\n# Clean coordinates\ndata_points <- data_clean %>%\n  filter(!is.na(latitude) & !is.na(longitude)) %>%\n  mutate(\n    Latitude = as.numeric(latitude),\n    Longitude = as.numeric(longitude)\n  )\n\n# Plot map\nggplot() +\n  \n  # County polygons\n  geom_sf(data = counties, fill = \"grey95\", color = \"black\", linewidth = 0.8) +\n  \n  # Elephant mortality points\n  geom_point(\n    data = data_points,\n    aes(x = longitude, y = latitude, color = cause_of_death_simplified),\n    size = 2.5,\n    alpha = 0.85\n  ) +\n  \n  # County labels\n  geom_sf_text(data = counties, aes(label = COUNTY),\n               size = 3.5, fontface = \"bold\") +\n  \n  # Colors for mortality causes\n  scale_color_brewer(palette = \"Set1\") +\n  \n  # Map labels\n  labs(\n    title = \"Spatial Distribution of Elephant Mortality\\nin Laikipia–Samburu Landscape (2015)\",\n    x = \"Longitude\",\n    y = \"Latitude\",\n    color = \"Cause of Death\"\n  ) +\n  \n  # Better theme\n  theme_minimal() +\n  \n  theme(\n    plot.title = element_text(size = 14, face = \"bold\", hjust = 0.5),\n    axis.title = element_text(size = 11),\n    legend.position = \"right\",\n    panel.grid.major = element_line(color = \"grey85\")\n  ) +\n  \n  coord_sf()","output":{"0":{"name":"stdout","output_type":"stream","text":"Reading layer `Laikipia_Samburu_Landscape' from data source \n  `/home/user/Capstone Project on Elephant Mortality Rate/Laikipia_Samburu_Landscapezip/Laikipia_Samburu_Landscape.shp' \n  using driver `ESRI Shapefile'\nSimple feature collection with 3 features and 8 fields\nGeometry type: POLYGON\nDimension:     XY\nBounding box:  xmin: 36.18384 ymin: -0.2961942 xmax: 39.46225 ymax: 2.516596\nGeodetic CRS:  WGS 84\n"},"1":{"name":"stderr","output_type":"stream","text":"Warning message in st_point_on_surface.sfc(sf::st_zm(x)):\n“st_point_on_surface may not give correct results for longitude/latitude data”\n"},"2":{"data":{"image/png":"0513685c6d02db57b7df863d350e6f88b1ec58d4","text/plain":"plot without title"},"exec_count":12,"metadata":{"image/png":{"height":420,"width":420}},"output_type":"execute_result"}},"pos":10,"type":"cell"}
{"cell_type":"code","exec_count":13,"id":"8be48d","input":"# SEX DISTRIBUTON (COUNTS + BAR CHART) (RQ3) (a)\n\n# Sex distribution\nsex_summary <- data_clean %>%\n  filter(!is.na(sex)) %>%   # remove missing values\n  count(sex)\n\nprint(sex_summary)\n\n# Bar chart for sex\nggplot(sex_summary, aes(x = sex, y = n, fill = sex)) +\n  geom_col() +\n  labs(\n    title = \"Sex Distribution of Elephant Mortality (2015)\",\n    x = \"Sex\",\n    y = \"Number of Deaths\"\n  ) +\n  theme_minimal() +\n  theme(legend.position = \"none\")","output":{"0":{"name":"stdout","output_type":"stream","text":"\u001b[90m# A tibble: 2 × 2\u001b[39m\n  sex        n\n  \u001b[3m\u001b[90m<chr>\u001b[39m\u001b[23m  \u001b[3m\u001b[90m<int>\u001b[39m\u001b[23m\n\u001b[90m1\u001b[39m Female    54\n\u001b[90m2\u001b[39m Male      99\n"},"1":{"data":{"image/png":"ef8b654f832cb21b38549663540065f067447f98","text/plain":"plot without title"},"exec_count":13,"metadata":{"image/png":{"height":420,"width":420}},"output_type":"execute_result"}},"pos":11,"type":"cell"}
{"cell_type":"code","exec_count":14,"id":"f90817","input":"# CLEAN AND GROUP AGE (RQ3) (b1)\n\ndata_clean <- data_clean %>%\n  mutate(\n    age_clean = tolower(age),  # make everything lowercase\n    \n    # Extract first number from age (e.g., \"15-20 yrs\" -> 15)\n    age_num = as.numeric(stringr::str_extract(age_clean, \"\\\\d+\")),\n    \n    # Create age groups\n    age_group = case_when(\n      age_num <= 10 ~ \"Juvenile\",\n      age_num > 10 & age_num <= 20 ~ \"Sub-adult\",\n      age_num > 20 ~ \"Adult\",\n      TRUE ~ NA_character_\n    ),\n    \n    # 🔹 Set correct order here\n    age_group = factor(age_group, levels = c(\"Juvenile\", \"Sub-adult\", \"Adult\"))\n  )\ntable(data_clean$age_group)","output":{"0":{"data":{"text/plain":"\n Juvenile Sub-adult     Adult \n       16        22        56 "},"exec_count":14,"output_type":"execute_result"}},"pos":12,"type":"cell"}
{"cell_type":"code","exec_count":15,"id":"bb4c58","input":"# AGE DISTRIBUTION (RQ3) (b2)\n\nage_group_summary <- data_clean %>%\n  filter(!is.na(age_group)) %>%\n  count(age_group) %>%\n  arrange(age_group)   # 🔹 ensures correct order\n\nprint(age_group_summary)\n\nggplot(age_group_summary, aes(x = age_group, y = n, fill = age_group)) +\n  geom_col() +\n  labs(\n    title = \"Age Distribution of Elephant Mortality (2015)\",\n    x = \"Age Group\",\n    y = \"Number of Deaths\"\n  ) +\n  theme_minimal() +\n  theme(legend.position = \"none\")","output":{"0":{"name":"stdout","output_type":"stream","text":"\u001b[90m# A tibble: 3 × 2\u001b[39m\n  age_group     n\n  \u001b[3m\u001b[90m<fct>\u001b[39m\u001b[23m     \u001b[3m\u001b[90m<int>\u001b[39m\u001b[23m\n\u001b[90m1\u001b[39m Juvenile     16\n\u001b[90m2\u001b[39m Sub-adult    22\n\u001b[90m3\u001b[39m Adult        56\n"},"1":{"data":{"image/png":"583c7b2a177f7e362a46c2838de0a117e82ea113","text/plain":"plot without title"},"exec_count":15,"metadata":{"image/png":{"height":420,"width":420}},"output_type":"execute_result"}},"pos":13,"type":"cell"}
{"cell_type":"code","exec_count":16,"id":"04f10b","input":"# SEX AND AGE COMBINED (RQ3) (c)\n\nsex_age_summary <- data_clean %>%\n  filter(!is.na(sex) & !is.na(age_group)) %>%   # use age_group\n  count(sex, age_group)\n\nprint(sex_age_summary)\n\n# Dodged bar chart (clean)\nggplot(sex_age_summary, aes(x = age_group, y = n, fill = sex)) +\n  geom_col(position = \"dodge\") +\n  labs(\n    title = \"Sex and Age Distribution of Elephant Mortality (2015)\",\n    x = \"Age Group\",\n    y = \"Number of Deaths\",\n    fill = \"Sex\"\n  ) +\n  theme_minimal()","output":{"0":{"name":"stdout","output_type":"stream","text":"\u001b[90m# A tibble: 6 × 3\u001b[39m\n  sex    age_group     n\n  \u001b[3m\u001b[90m<chr>\u001b[39m\u001b[23m  \u001b[3m\u001b[90m<fct>\u001b[39m\u001b[23m     \u001b[3m\u001b[90m<int>\u001b[39m\u001b[23m\n\u001b[90m1\u001b[39m Female Juvenile      5\n\u001b[90m2\u001b[39m Female Sub-adult     8\n\u001b[90m3\u001b[39m Female Adult        18\n\u001b[90m4\u001b[39m Male   Juvenile      9\n\u001b[90m5\u001b[39m Male   Sub-adult    14\n\u001b[90m6\u001b[39m Male   Adult        36\n"},"1":{"data":{"image/png":"b38f7d8c592a3487d2d6a686abe65d2595ef0e2b","text/plain":"plot without title"},"exec_count":16,"metadata":{"image/png":{"height":420,"width":420}},"output_type":"execute_result"}},"pos":14,"type":"cell"}
